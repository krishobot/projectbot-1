# astack web console — environment template
# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase project (the SaaS / multi-user path).
# Leave both blank to run in single-user local mode (no auth).
# Find these at: https://supabase.com/dashboard/project/<your-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: override the desktop companion endpoint.
# Defaults: ASTACK_DESKTOP_HOST=127.0.0.1, ASTACK_DESKTOP_PORT=7331
# ASTACK_DESKTOP_HOST=
# ASTACK_DESKTOP_PORT=
